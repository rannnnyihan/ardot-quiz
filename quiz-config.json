      "options": [
        { "key": "A", "label": "A. 把脑子里的奇怪想法做出来",      "scoreRole": "d1", "scoreValue": 1 },
        { "key": "B", "label": "B. 探索一遍新的工具",              "scoreRole": "d6", "scoreValue": 1 },
        { "key": "C", "label": "C. 慢慢整理回顾之前的作品",         "scoreRole": "d5", "scoreValue": 1 },
        { "key": "D", "label": "D. 脱离重复工作，放空充电",         "scoreRole": "d4", "scoreValue": 1 }
      ]
    },
