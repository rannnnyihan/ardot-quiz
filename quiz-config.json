  "roles": [
    {
      "id": "d1",
      "name": "草稿太多的毕加班索",
      "real": "D1 · 灵感发散与筛选",
      "img": "role/d1-B.png",
      "desc": "你脑子里永远有想法，AI 一问还能再炸出一百种方向。问题不是没灵感，而是筛不动、收不住——画到最后连自己都忘了最开始想画什么。"
    },
    {
      "id": "d2",
      "name": "还在抠图的原研栽",
      "real": "D2 · 图像与素材处理",
      "img": "role/d2-B.png",
      "desc": "你对质感和细节极度敏感，AI 抠图、去背、修边、放大总是差那一口气。不是做不到，是不能接受“差不多”——宁可自己再抠一次。"
    },
    {
      "id": "d3",
      "name": "对不齐的蒙得里不安",
      "real": "D3 · 版式与结构处理",
      "img": "role/d3-B.png",
      "desc": "你对结构、栅格、规范有近乎强迫症的追求。AI 出的布局总是“像那么回事但就是不对齐”，你不得不亲手一格一格把它掰正。"
    },
    {
      "id": "d4",
      "name": "复制到崩溃的草间弥想鼠",
      "real": "D4 · 重复执行与批量操作",
      "img": "role/d4-B.png",
      "desc": "你最怕的不是创意，而是“把同一个改动复制 83 次”。AI 批量处理要么配置半天、要么改得不一致，最后还是要逐个检查到崩溃。"
    },
    {
      "id": "d5",
      "name": "风格断片的梵稿",
      "real": "D5 · 项目上下文管理",
      "img": "role/d5-B.png",
      "desc": "你希望 AI 真正记得你之前的风格、规范、历史方案。但它每次开新对话都像失忆——你一边讲设计，一边像在写回忆录。"
    },
    {
      "id": "d6",
      "name": "睡莲迁移失败的莫奈何",
      "real": "D6 · 工作流衔接",
      "img": "role/d6-B.png",
      "desc": "你最关注的是“稿子能不能顺利交出去”：一键原型、标注、跨软件同步。AI 能做一半，另一半永远要你在不同工具之间来回搬运。"
    }
  ],
  "questions": {
    "q1": {
      "type": "single",
      "minSelect": 1,
      "title": "作为设计师，你最怀念的状态什么时候？",
      "desc": "",
      "mapsToRoles": true,
      "scoreKind": "optionRole",
      "_designNote": "Q1 单选。每个选项打到不同维度：A 敢发散→d1；B 慢磨细节→d2；C 风格规范→d3；D 不被流程切碎→d6。",
      "options": [
        { "key": "A", "label": "A. 刚学设计，什么都敢试",                          "scoreRole": "d1", "scoreValue": 1 },
        { "key": "B", "label": "B. 抠图修图也愿意慢慢磨细节",                       "scoreRole": "d2", "scoreValue": 1 },
        { "key": "C", "label": "C. 可以按自己的风格和规范做",                       "scoreRole": "d3", "scoreValue": 1 },
        { "key": "D", "label": "D. 只做设计本身，不被流程和沟通切碎时间",             "scoreRole": "d6", "scoreValue": 1 }
      ]
    },
